# ClickHouse connection (required for API and server-side tracking)
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Optional: override API endpoint for client-side tracking (default: /api/events)
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=/api/events

# Optional: app URL for server-side fetch (only if using API instead of direct insert)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
